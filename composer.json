{
    "name": "letsdeploy/reviews",
    "autoload": {
        "psr-4": {
            "Letsdeploy\\Reviews\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Letsdeploy\\Reviews\\Tests\\": "tests"
        }
    },
    "require": {
        "statamic/cms": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    },
    "extra": {
        "statamic": {
            "name": "Reviews",
            "description": "Reviews addon"
        },
        "laravel": {
            "providers": [
                "Letsdeploy\\Reviews\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
